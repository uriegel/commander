{
  "name": "commander",
  "version": "1.4.7",
  "description": "A Norton Commander clone based on Electron and React with Typescript",
  "main": "dist/main/main.js",
  "type": "module",
  "author": {
    "name": "Uwe Riegel",
    "email": "uriegel@hotmail.de"
  },
  "scripts": {
    "dev": "vite",
    "lint": "tsc && vite build && eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "build": "tsc && vite build && npm run copy",
    "build Windows": "tsc && vite build && npm run wincopy",
    "copy": "cp dist/renderer/index.html Commander/Resources/index.html && cp dist/renderer/assets/*.js Commander/Resources/assets/ && cp dist/renderer/assets/*.css Commander/Resources/assets/",
    "wincopy": "xcopy .\\dist\\renderer\\index.html .\\Commander\\Resources\\index.html && xcopy .\\dist\\renderer\\assets\\*.js .\\Commander\\Resources\\assets /y &&  copy .\\dist\\renderer\\assets\\*.css .\\Commander\\Resources\\assets /y"

  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uriegel/commander.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/uriegel/commander/issues"
  },
  "homepage": "https://github.com/uriegel/commander#readme",
  "dependencies": {
    "functional-extensions": "^2.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "cross-env": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "leaflet": "^1.9.4",
    "menubar-react": "^2.3.3",
    "react-leaflet": "^5.0.0",
    "react-progress-control": "^1.1.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.48.1",
    "view-split-react": "^1.2.0",
    "virtual-table-react": "^10.13.0",
    "vite": "8.0.10",
    "web-dialog-react": "^5.2.0"
  }
}